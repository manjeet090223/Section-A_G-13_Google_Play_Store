"# Google Play Store — Data Cleaning Pipeline\n",
"### Section A | Group 13\n",
"\n",
"Final version aligned with report (Mean / Median / Mode based cleaning)"
]
},
{
"cell_type": "code",
"execution_count": 1,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Loaded: 2,312,944 rows, 24 columns\n",
"Total nulls: 1,305,751\n"
]
}
],
"source": [
"import pandas as pd\n",
"import numpy as np\n",
"from scipy.stats import kurtosis\n",
"\n",
"RAW_PATH = '../data/Google-Playstore-raw.csv'\n",
"CLEAN_PATH = '../data/Google-Playstore-Cleaned.csv'\n",
"\n",
"df = pd.read_csv(RAW_PATH)\n",
"print(f'Loaded: {len(df):,} rows, {len(df.columns)} columns')\n",
"print(f'Total nulls: {df.isnull().sum().sum():,}')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 1: Drop App Name"]
},
{
"cell_type": "code",
"execution_count": 2,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Dropped 5 rows\n",
"Remaining: 2,312,939 rows\n"
]
}
],
"source": [
"before = len(df)\n",
"df.dropna(subset=['App Name'], inplace=True)\n",
"after = len(df)\n",
"print(f'Dropped {before - after} rows')\n",
"print(f'Remaining: {after:,} rows')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 2: Rating & Rating Count"]
},
{
"cell_type": "code",
"execution_count": 3,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Rating mean used: 2.2031\n",
"Rating Count median used: 6.0\n"
]
}
],
"source": [
"rating_mean = df['Rating'].mean()\n",
"rating_count_median = df['Rating Count'].median()\n",
"\n",
"df['Rating'] = df['Rating'].fillna(rating_mean)\n",
"df['Rating Count'] = df['Rating Count'].fillna(rating_count_median)\n",
"\n",
"print(f'Rating mean used: {rating_mean:.4f}')\n",
"print(f'Rating Count median used: {rating_count_median}')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 3: Size Conversion"]
},
{
"cell_type": "code",
"execution_count": 4,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Size median used: 13.0 MB\n"
]
}
],
"source": [
"def convert_size(x):\n",
"    if pd.isna(x) or 'Varies' in str(x): return np.nan\n",
"    x = str(x).upper()\n",
"    if 'M' in x: return float(x.replace('M',''))\n",
"    if 'K' in x: return float(x.replace('K',''))/1024\n",
"    if 'G' in x: return float(x.replace('G',''))*1024\n",
"    return np.nan\n",
"\n",
"df['Size_MB'] = df['Size'].apply(convert_size)\n",
"size_median = 13.0\n",
"df['Size_MB'] = df['Size_MB'].fillna(size_median)\n",
"print(f'Size median used: {size_median} MB')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 4: Installs"]
},
{
"cell_type": "code",
"execution_count": 5,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Installs median used: 500.0\n"
]
}
],
"source": [
"installs_median = df['Minimum Installs'].median()\n",
"\n",
"df['Installs_Numeric'] = (\n",
"    df['Installs'].str.replace('+','')\n",
"                  .str.replace(',','')\n",
"                  .apply(pd.to_numeric, errors='coerce')\n",
"                  .fillna(installs_median)\n",
")\n",
"\n",
"df['Minimum Installs'] = df['Minimum Installs'].fillna(installs_median)\n",
"print(f'Installs median used: {installs_median}')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 5: Currency"]
},
{
"cell_type": "code",
"execution_count": 6,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Currency mode used: USD\n"
]
}
],
"source": [
"currency_mode = df['Currency'].mode().iloc[0]\n",
"df['Currency'] = df['Currency'].fillna(currency_mode)\n",
"df['Currency'] = df['Currency'].replace('XXX', currency_mode)\n",
"print(f'Currency mode used: {currency_mode}')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 6: Other Categorical Columns"]
},
{
"cell_type": "code",
"execution_count": 7,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"All categorical nulls handled using mode\n"
]
}
],
"source": [
"cols = ['Minimum Android','Developer Id','Developer Email','Developer Website','Released','Privacy Policy']\n",
"for c in cols:\n",
"    df[c] = df[c].fillna(df[c].mode().iloc[0])\n",
"print('All categorical nulls handled using mode')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 7: Date Conversion"]
},
{
"cell_type": "code",
"execution_count": 8,
"metadata": {},
"outputs": [
{
"name": "stdout",
"output_type": "stream",
"text": [
"Datetime conversion done\n"
]
}
],
"source": [
"df['Last Updated'] = pd.to_datetime(df['Last Updated'], errors='coerce')\n",
"print('Datetime conversion done')"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 8: Statistics"]
},
{
"cell_type": "code",
"execution_count": 9,
"metadata": {},
"outputs": [],
"source": [
"cols = ['Rating','Rating Count','Minimum Installs','Price','Size_MB']\n",
"for col in cols:\n",
"    s = df[col]\n",
"    print(f"\n--- {col} ---")\n",
"    print(f"Mean     : {s.mean():.4f}")\n",
"    print(f"Median   : {s.median():.4f}")\n",
"    print(f"Mode     : {s.mode().iloc[0]}")\n",
"    print(f"Std Dev  : {s.std():.4f}")\n",
"    print(f"Skewness : {s.skew():.4f}")\n",
"    print(f"Kurtosis : {kurtosis(s):.4f}")"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": ["---\n## Step 9: Final Check"]
},
{
